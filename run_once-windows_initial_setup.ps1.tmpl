{{- $isWork := false -}}
{{- $hostname := .chezmoi.hostname -}}
{{- $fqdn := .chezmoi.fqdnHostname -}}

{{/* Check if it's a work machine based on hostname patterns */}}
{{- if or (hasPrefix "WD" $hostname) (contains "deere" $fqdn) -}}
    {{- $isWork = true -}}
{{- end -}}

{{/* Personal machine check based on hostname patterns */}}
{{- $isPersonal := or (contains "DESKTOP" $hostname) (contains .chezmoi.username $hostname) -}}

{{- if $isWork }}

{{- else if $isPersonal }}
{{ range .packages.personal.windows.winget -}}
winget install -e id={{ . }}
{{ end -}}


{{ end }}
{{ end -}}
